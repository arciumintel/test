# ─── Database (Neon Postgres) ────────────────────────────────────────────────
# Pooled connection string used by the app at runtime.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require&pgbouncer=true"
# Direct (non-pooled) connection used by Prisma migrations.
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# ─── Auth (Solana wallet session) ────────────────────────────────────────────
# 32+ char random secret used to sign session JWTs. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
AUTH_SECRET="replace-with-a-long-random-secret"
# Public Solana cluster used for display/links (devnet | mainnet-beta | testnet).
NEXT_PUBLIC_SOLANA_CLUSTER="devnet"

# ─── Cloudinary ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"
# Unsigned upload preset for client-side widget uploads.
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET="arcademy_unsigned"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ─── Bootstrap ───────────────────────────────────────────────────────────────
# Comma-separated wallet addresses granted staff_admin on first sign-in / seed.
STAFF_ADMIN_WALLETS=""
