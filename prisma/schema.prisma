// Arcademy V1 — Prisma schema
// Source of truth: Neon Postgres. See docs/PRD.md and CONTEXT.md.

generator client {
  provider = "prisma-client"
  output   = "../generated"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  learner
  staff_admin
}

enum CourseLevel {
  beginner
  intermediate
  advanced
}

enum CourseStatus {
  draft
  partner_draft
  submitted_for_review
  staff_changes_requested
  approved
  published
  archived
}

enum ProductStatus {
  draft
  published
  archived
}

enum ProductRole {
  foundation
  ecosystem
}

enum LessonStatus {
  draft
  published
}

enum CourseType {
  foundational
  product_onboarding
  builder_intro
}

enum QuizType {
  final_course_quiz
  lesson_knowledge_check
}

enum LearningPathStatus {
  draft
  published
}

enum QuizStatus {
  draft
  published
}

enum BadgeStatus {
  draft
  published
  archived
}

enum PartnerIntakeReviewStatus {
  received
  in_review
  draft_created
  partner_review
  approved
  published
  rejected
}

enum ProjectAdminRole {
  owner
  manager
}

enum ProjectDiscordIntegrationStatus {
  draft
  active
  paused
}

enum DiscordRoleRuleStatus {
  draft
  active
  paused
}

enum DiscordRoleGrantStatus {
  pending
  granted
  skipped_discord_not_linked
  failed_user_not_in_server
  failed_missing_bot_permission
  failed_role_hierarchy
  failed_rate_limited
  failed_unknown
}

model Product {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  description String
  logoUrl     String?
  bannerUrl   String?
  category    String?
  role        ProductRole   @default(ecosystem)
  learningOutcomes String[] @default([])
  featured    Boolean       @default(false)
  featuredOrder Int?
  links       Json          @default("[]")
  partnerName             String?
  referralUrl             String?
  partnerAnalyticsNotes   String?
  status                  ProductStatus @default(draft)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  courses                 Course[]
  partnerIntakes          PartnerIntake[]
  projectAdmins           ProjectAdmin[]
  projectDiscordIntegration ProjectDiscordIntegration?
  learningPaths           LearningPath[]

  @@index([status])
}

/// Learner / admin identity, anchored to a Solana wallet address.
model User {
  id            String   @id @default(cuid())
  walletAddress String   @unique
  displayName   String?
  role          Role     @default(learner)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  progress     Progress[]
  quizAttempts QuizAttempt[]
  badgeAwards  BadgeAward[]
  discordAccount DiscordAccount?
  projectAdmins  ProjectAdmin[] @relation("ProjectAdminUser")
  invitedProjectAdmins ProjectAdmin[] @relation("ProjectAdminInviter")
  createdDiscordIntegrations ProjectDiscordIntegration[]
  discordRoleGrants DiscordRoleGrant[]
  coursesSubmittedForReview Course[] @relation("CourseReviewRequestedBy")
  coursesReviewed           Course[] @relation("CourseReviewedBy")
  partnerIntakeApplications PartnerIntake[] @relation("PartnerIntakeApplicant")
  notifications             Notification[]
}

/// One-time challenge used to verify wallet ownership during sign-in.
model AuthNonce {
  id            String   @id @default(cuid())
  walletAddress String
  nonce         String   @unique
  expiresAt     DateTime
  createdAt     DateTime @default(now())

  @@index([walletAddress])
}

/// A published or draft course owned by a staff-managed ecosystem product.
model Course {
  id                String        @id @default(cuid())
  productId         String
  title             String
  slug              String
  summary           String
  description       String?
  level                 CourseLevel  @default(beginner)
  status                CourseStatus @default(draft)
  thumbnailUrl          String?
  estimatedDuration     Int? // minutes
  learningOutcomes      String[] // bullet list of "what you'll learn"
  courseType            CourseType   @default(foundational)
  prerequisiteCourseIds String[]     @default([])
  submittedForReviewAt  DateTime?
  reviewedAt            DateTime?
  staffReviewNotes      String?
  reviewRequestedByUserId String?
  reviewedByUserId      String?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  product             Product @relation(fields: [productId], references: [id])
  reviewRequestedBy   User?   @relation("CourseReviewRequestedBy", fields: [reviewRequestedByUserId], references: [id], onDelete: SetNull)
  reviewedBy          User?   @relation("CourseReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  lessons     Lesson[]
  modules     Module[]
  quizzes     Quiz[]
  progress    Progress[]
  badge       Badge?
  badgeAwards BadgeAward[]
  pathCourses LearningPathCourse[]

  @@unique([productId, slug])
  @@index([status])
  @@index([productId])
}

/// Groups lessons inside a course (optional; flat lessons when absent).
model Module {
  id          String   @id @default(cuid())
  courseId    String
  title       String
  description String?
  order       Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@unique([courseId, order])
  @@index([courseId])
}

/// One ordered learning unit inside a course.
model Lesson {
  id                String       @id @default(cuid())
  courseId          String
  moduleId          String?
  title             String
  order             Int
  content           String // rich text / markdown
  mediaUrl          String?
  status            LessonStatus @default(draft)
  required          Boolean      @default(true)
  estimatedDuration Int? // minutes
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  course   Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  module   Module?    @relation(fields: [moduleId], references: [id], onDelete: SetNull)
  quizzes  Quiz[]
  progress Progress[]

  @@unique([courseId, order])
  @@index([courseId])
  @@index([moduleId])
}

/// An assessment for a course (final quiz) or a specific lesson.
model Quiz {
  id            String     @id @default(cuid())
  courseId      String
  lessonId      String?
  title         String     @default("Course Quiz")
  description   String?
  type          QuizType   @default(final_course_quiz)
  passThreshold Int        @default(70) // percent required to pass
  status        QuizStatus @default(published)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  course    Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lesson    Lesson?       @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  questions Question[]
  attempts  QuizAttempt[]

  @@index([courseId])
  @@index([lessonId])
  @@unique([lessonId])
}

/// Curated multi-course sequence for an ecosystem product.
model LearningPath {
  id          String              @id @default(cuid())
  productId   String
  title       String
  slug        String
  description String?
  order       Int                 @default(0)
  status      LearningPathStatus  @default(draft)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  product Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  courses LearningPathCourse[]

  @@unique([productId, slug])
  @@index([productId])
}

model LearningPathCourse {
  id       String @id @default(cuid())
  pathId   String
  courseId String
  order    Int

  path   LearningPath @relation(fields: [pathId], references: [id], onDelete: Cascade)
  course Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([pathId, courseId])
  @@unique([pathId, order])
  @@index([courseId])
}

/// In-app notification for a learner.
model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String?
  actionUrl String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

/// One multiple-choice quiz question.
model Question {
  id            String   @id @default(cuid())
  quizId        String
  prompt        String
  answerOptions String[] // ordered options
  correctAnswer Int // index into answerOptions
  explanation   String?
  order         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId])
}

/// Tracks per-lesson completion for a learner within a course.
model Progress {
  id          String    @id @default(cuid())
  userId      String
  courseId    String
  lessonId    String
  completed   Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId, courseId])
}

/// A submitted quiz with score and pass/fail outcome.
model QuizAttempt {
  id          String   @id @default(cuid())
  userId      String
  quizId      String
  score       Int // percent 0-100
  passed      Boolean
  answers     Json? // recorded selections for feedback
  submittedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([quizId])
}

/// Course completion badge definition.
model Badge {
  id          String      @id @default(cuid())
  courseId    String      @unique
  name        String
  description String
  imageUrl    String?
  criteria    String?
  issuer      String?
  status      BadgeStatus @default(published)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  course Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  awards BadgeAward[]
  discordRoleRules DiscordRoleRule[]
}

/// A badge granted to a learner (off-chain in V1).
model BadgeAward {
  id               String   @id @default(cuid())
  userId           String
  badgeId          String
  courseId         String
  walletAddress    String?
  verificationSlug String?  @unique
  awardedAt        DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge  Badge  @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  discordRoleGrants DiscordRoleGrant[]

  @@unique([userId, badgeId])
  @@index([userId])
}

/// Learner-linked Discord identity (OAuth profile only; no token retention).
model DiscordAccount {
  id            String   @id @default(cuid())
  userId        String   @unique
  discordUserId String   @unique
  username      String
  globalName    String?
  avatar        String?
  linkedAt      DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user   User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  grants DiscordRoleGrant[]

  @@index([discordUserId])
}

/// Wallet-based project admin assignment (owner or manager).
model ProjectAdmin {
  id              String           @id @default(cuid())
  productId       String
  userId          String
  role            ProjectAdminRole @default(manager)
  invitedByUserId String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User    @relation("ProjectAdminUser", fields: [userId], references: [id], onDelete: Cascade)
  invitedBy User?   @relation("ProjectAdminInviter", fields: [invitedByUserId], references: [id], onDelete: SetNull)

  @@unique([productId, userId])
  @@index([userId])
}

/// One Discord guild integration per ecosystem product.
model ProjectDiscordIntegration {
  id                        String                          @id @default(cuid())
  productId                 String                          @unique
  guildId                   String
  guildName                 String
  status                    ProjectDiscordIntegrationStatus @default(draft)
  botInstalled              Boolean                         @default(false)
  lastPermissionCheckStatus String?
  lastPermissionCheckAt     DateTime?
  createdByUserId           String?
  createdAt                 DateTime                        @default(now())
  updatedAt                 DateTime                        @updatedAt

  product   Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdBy User?             @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  roleRules DiscordRoleRule[]

  @@index([guildId])
}

/// Maps one published badge to one Discord role in a project server.
model DiscordRoleRule {
  id                          String                @id @default(cuid())
  productDiscordIntegrationId String
  badgeId                     String
  discordRoleId               String
  discordRoleName             String
  unlockLabel                 String?
  status                      DiscordRoleRuleStatus @default(draft)
  createdAt                   DateTime              @default(now())
  updatedAt                   DateTime              @updatedAt

  integration ProjectDiscordIntegration @relation(fields: [productDiscordIntegrationId], references: [id], onDelete: Cascade)
  badge       Badge                     @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  grants      DiscordRoleGrant[]

  @@unique([productDiscordIntegrationId, badgeId])
  @@unique([productDiscordIntegrationId, discordRoleId])
  @@index([badgeId])
}

/// Async job to grant a Discord role after a badge award.
model DiscordRoleGrant {
  id                String                 @id @default(cuid())
  userId            String
  discordAccountId  String?
  badgeAwardId      String
  discordRoleRuleId String
  guildId           String
  roleId            String
  status            DiscordRoleGrantStatus @default(pending)
  attemptCount      Int                    @default(0)
  lastAttemptAt     DateTime?
  grantedAt         DateTime?
  lastErrorCode     String?
  lastErrorMessage  String?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  discordAccount  DiscordAccount? @relation(fields: [discordAccountId], references: [id], onDelete: SetNull)
  badgeAward      BadgeAward      @relation(fields: [badgeAwardId], references: [id], onDelete: Cascade)
  discordRoleRule DiscordRoleRule @relation(fields: [discordRoleRuleId], references: [id], onDelete: Cascade)

  @@unique([badgeAwardId, discordRoleRuleId])
  @@index([status])
  @@index([userId])
}

/// Internal partner intake tracking and self-serve partner applications.
model PartnerIntake {
  id                   String                    @id @default(cuid())
  productId            String?
  applicantUserId      String?
  partnerName          String
  contactName          String?
  contactEmail         String?
  projectName          String?
  projectDescription   String?
  sourceMaterialUrl    String?
  requestedCourseTopic String?
  reviewStatus         PartnerIntakeReviewStatus @default(received)
  notes                String?
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt

  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  applicant User?    @relation("PartnerIntakeApplicant", fields: [applicantUserId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([reviewStatus])
  @@index([applicantUserId])
}

/// Append-only funnel and audit events (additive instrumentation).
model AnalyticsEvent {
  id                   String   @id @default(cuid())
  eventName            String
  occurredAt           DateTime @default(now())
  anonymousId          String?
  userId               String?
  walletAddress        String?
  sessionId            String?
  source               String
  path                 String?
  referrer             String?
  utmSource            String?
  utmMedium            String?
  utmCampaign          String?
  utmContent           String?
  ecosystemProjectId   String?
  ecosystemProjectSlug String?
  courseId             String?
  courseSlug           String?
  lessonId             String?
  quizId               String?
  badgeId              String?
  badgeAwardId         String?
  verificationSlug     String?
  metadata             Json?
  createdAt            DateTime @default(now())

  @@index([eventName])
  @@index([occurredAt])
  @@index([userId])
  @@index([courseId])
  @@index([ecosystemProjectId])
  @@index([ecosystemProjectId, eventName, occurredAt])
}
