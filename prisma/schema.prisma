// Arcademy V1 — Prisma schema
// Source of truth: Neon Postgres. See docs/PRD.md and CONTEXT.md.

generator client {
  provider = "prisma-client"
  output   = "../generated"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  learner
  staff_admin
}

enum CourseLevel {
  beginner
  intermediate
  advanced
}

enum CourseStatus {
  draft
  partner_draft
  submitted_for_review
  staff_changes_requested
  approved
  published
  archived
}

enum ProductStatus {
  draft
  published
  archived
}

enum ProductRole {
  foundation
  ecosystem
}

enum DirectoryNetworkStatus {
  mainnet
  testnet
  coming_soon
}

enum LessonStatus {
  draft
  published
}

enum CourseType {
  foundational
  product_onboarding
  builder_intro
}

enum QuizType {
  final_course_quiz
  lesson_knowledge_check
}

enum LearningPathStatus {
  draft
  published
}

enum QuizStatus {
  draft
  published
}

enum QuestionType {
  single_select
  true_false
  image_select
  scenario_select
  multi_select
  ordering
  matching
  fill_blank
}

enum BadgeStatus {
  draft
  published
  archived
}

enum PartnerIntakeReviewStatus {
  received
  in_review
  draft_created
  partner_review
  approved
  published
  rejected
}

enum PartnerPreferredContactMethod {
  email
  x
  discord
  telegram
}

enum ProjectAdminRole {
  owner
  manager
  analyst
}

enum ConceptImportance {
  critical
  core
  supporting
}

enum ConceptRelationType {
  prerequisite
}

enum CertificationStatus {
  draft
  published
}

enum CertificationRequirementType {
  course_completion
  quiz_pass
  readiness_score
  learning_path_completion
  conversion_event
  concept_mastery
}

enum ProjectDiscordIntegrationStatus {
  draft
  active
  paused
}

enum DiscordRoleRuleStatus {
  draft
  active
  paused
}

enum DiscordRoleGrantStatus {
  pending
  granted
  skipped_discord_not_linked
  failed_user_not_in_server
  failed_missing_bot_permission
  failed_role_hierarchy
  failed_rate_limited
  failed_unknown
}

model Product {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  description String
  logoUrl     String?
  bannerUrl   String?
  category    String?
  role        ProductRole   @default(ecosystem)
  learningOutcomes String[] @default([])
  featured    Boolean       @default(false)
  featuredOrder Int?
  links       Json          @default("[]")
  partnerName             String?
  referralUrl             String?
  partnerAnalyticsNotes   String?
  status                  ProductStatus @default(draft)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  courses                 Course[]
  partnerIntakes          PartnerIntake[]
  projectAdmins           ProjectAdmin[]
  projectDiscordIntegration ProjectDiscordIntegration?
  learningPaths           LearningPath[]
  ecosystemDirectoryEntry EcosystemDirectoryEntry?
  analyticsProfile        AnalyticsProfile?
  concepts                Concept[]
  skillCategories         SkillCategory[]
  learningObjectives      LearningObjective[]
  conversionDefinitions   ConversionDefinition[]
  readinessModels         ReadinessModel[]
  certifications          Certification[]
  analyticsPackInstalls   AnalyticsPackInstall[]
  analyticsSnapshots      AnalyticsSnapshot[]

  @@index([status])
}

/// Staff-curated Arcium ecosystem directory entry for /ecosystem.
/// Optional link to Product supplies live learning overlay when published.
model EcosystemDirectoryEntry {
  id            String                 @id @default(cuid())
  slug          String                 @unique
  productId     String?                @unique
  name          String
  tagline       String                 @default("")
  description   String
  logoUrl       String?
  categoryId    String
  networkStatus DirectoryNetworkStatus @default(mainnet)
  featured      Boolean                @default(false)
  trending      Boolean                @default(false)
  tags          String[]               @default([])
  links         Json                   @default("{}")
  relationships Json                   @default("[]")
  addedAt       DateTime               @default(now())
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([categoryId])
  @@index([networkStatus])
}

/// Learner / admin identity, anchored to a Solana wallet address.
model User {
  id            String   @id @default(cuid())
  walletAddress String   @unique
  displayName   String?
  role          Role     @default(learner)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  progress     Progress[]
  quizAttempts QuizAttempt[]
  questionAttempts QuestionAttempt[]
  badgeAwards  BadgeAward[]
  certificationAwards CertificationAward[]
  discordAccount DiscordAccount?
  projectAdmins  ProjectAdmin[] @relation("ProjectAdminUser")
  invitedProjectAdmins ProjectAdmin[] @relation("ProjectAdminInviter")
  createdDiscordIntegrations ProjectDiscordIntegration[]
  discordRoleGrants DiscordRoleGrant[]
  coursesSubmittedForReview Course[] @relation("CourseReviewRequestedBy")
  coursesReviewed           Course[] @relation("CourseReviewedBy")
  partnerIntakeApplications PartnerIntake[] @relation("PartnerIntakeApplicant")
  notifications             Notification[]
}

/// One-time challenge used to verify wallet ownership during sign-in.
model AuthNonce {
  id            String   @id @default(cuid())
  walletAddress String
  nonce         String   @unique
  expiresAt     DateTime
  createdAt     DateTime @default(now())

  @@index([walletAddress])
}

/// A published or draft course owned by a staff-managed ecosystem product.
model Course {
  id                String        @id @default(cuid())
  productId         String
  title             String
  slug              String
  summary           String
  description       String?
  level                 CourseLevel  @default(beginner)
  status                CourseStatus @default(draft)
  thumbnailUrl          String?
  estimatedDuration     Int? // minutes
  learningOutcomes      String[] // bullet list of "what you'll learn"
  courseType            CourseType   @default(foundational)
  prerequisiteCourseIds String[]     @default([])
  submittedForReviewAt  DateTime?
  reviewedAt            DateTime?
  staffReviewNotes      String?
  reviewRequestedByUserId String?
  reviewedByUserId      String?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  product             Product @relation(fields: [productId], references: [id])
  reviewRequestedBy   User?   @relation("CourseReviewRequestedBy", fields: [reviewRequestedByUserId], references: [id], onDelete: SetNull)
  reviewedBy          User?   @relation("CourseReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  lessons     Lesson[]
  modules     Module[]
  quizzes     Quiz[]
  progress    Progress[]
  badge       Badge?
  badgeAwards BadgeAward[]
  pathCourses LearningPathCourse[]

  @@unique([productId, slug])
  @@index([status])
  @@index([productId])
}

/// Groups lessons inside a course (optional; flat lessons when absent).
model Module {
  id          String   @id @default(cuid())
  courseId    String
  title       String
  description String?
  order       Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@unique([courseId, order])
  @@index([courseId])
}

/// One ordered learning unit inside a course.
model Lesson {
  id                String       @id @default(cuid())
  courseId          String
  moduleId          String?
  title             String
  order             Int
  content           String // rich text / markdown
  mediaUrl          String?
  status            LessonStatus @default(draft)
  required          Boolean      @default(true)
  estimatedDuration Int? // minutes
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  course   Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  module   Module?    @relation(fields: [moduleId], references: [id], onDelete: SetNull)
  quizzes  Quiz[]
  progress Progress[]
  conceptTags ContentConceptTag[]

  @@unique([courseId, order])
  @@index([courseId])
  @@index([moduleId])
}

/// An assessment for a course (final quiz) or a specific lesson.
model Quiz {
  id            String     @id @default(cuid())
  courseId      String
  lessonId      String?
  title         String     @default("Course Quiz")
  description   String?
  type          QuizType   @default(final_course_quiz)
  passThreshold Int        @default(70) // percent required to pass
  status        QuizStatus @default(published)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  course    Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lesson    Lesson?       @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  questions Question[]
  attempts  QuizAttempt[]

  @@index([courseId])
  @@index([lessonId])
  @@unique([lessonId])
}

/// Curated multi-course sequence for an ecosystem product.
model LearningPath {
  id          String              @id @default(cuid())
  productId   String
  title       String
  slug        String
  description String?
  order       Int                 @default(0)
  status      LearningPathStatus  @default(draft)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  product Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  courses LearningPathCourse[]

  @@unique([productId, slug])
  @@index([productId])
}

model LearningPathCourse {
  id       String @id @default(cuid())
  pathId   String
  courseId String
  order    Int

  path   LearningPath @relation(fields: [pathId], references: [id], onDelete: Cascade)
  course Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([pathId, courseId])
  @@unique([pathId, order])
  @@index([courseId])
}

/// In-app notification for a learner.
model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String?
  actionUrl String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

/// A quiz question. Supports multiple auto-graded question types.
model Question {
  id                String       @id @default(cuid())
  quizId            String
  type              QuestionType @default(single_select)
  prompt            String
  mediaUrl          String?
  answerOptions     String[] // MC options, ordering items, or matching right column
  leftItems         String[] // matching left column prompts
  correctAnswer     Int        @default(0) // single-select family
  correctAnswers    Int[] // multi-select correct indices
  correctOrder      Int[] // ordering: permutation of answerOptions indices
  correctMatches    Int[] // matching: right-column index per left item
  acceptableAnswers String[] // fill-in-the-blank accepted responses
  explanation       String?
  order             Int        @default(0)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
  conceptTags ContentConceptTag[]
  questionAttempts QuestionAttempt[]

  @@index([quizId])
}

/// Tracks per-lesson completion for a learner within a course.
model Progress {
  id          String    @id @default(cuid())
  userId      String
  courseId    String
  lessonId    String
  completed   Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId, courseId])
}

/// A submitted quiz with score and pass/fail outcome.
model QuizAttempt {
  id                 String   @id @default(cuid())
  userId             String
  quizId             String
  score              Int // percent 0-100
  passed             Boolean
  answers            Json? // recorded selections for feedback (compat)
  durationInSeconds  Int? // client-measured time from quiz start to submit
  submittedAt        DateTime @default(now())

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz             Quiz              @relation(fields: [quizId], references: [id], onDelete: Cascade)
  questionAttempts QuestionAttempt[]

  @@index([userId])
  @@index([quizId])
}

/// Normalized per-question answer row (dual-written with QuizAttempt.answers JSON).
model QuestionAttempt {
  id            String   @id @default(cuid())
  userId        String
  quizAttemptId String
  questionId    String
  correct       Boolean
  answerPayload Json
  durationMs    Int?
  hintUsed      Boolean  @default(false)
  submittedAt   DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  quizAttempt QuizAttempt @relation(fields: [quizAttemptId], references: [id], onDelete: Cascade)
  question    Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([quizAttemptId, questionId])
  @@index([questionId, submittedAt])
  @@index([userId, submittedAt])
  @@index([submittedAt])
}

/// Course completion badge definition.
model Badge {
  id          String      @id @default(cuid())
  courseId    String      @unique
  name        String
  description String
  imageUrl    String?
  criteria    String?
  issuer      String?
  status      BadgeStatus @default(published)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  course Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  awards BadgeAward[]
  discordRoleRules DiscordRoleRule[]
}

/// A badge granted to a learner (off-chain in V1).
model BadgeAward {
  id               String   @id @default(cuid())
  userId           String
  badgeId          String
  courseId         String
  walletAddress    String?
  verificationSlug String?  @unique
  awardedAt        DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge  Badge  @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  discordRoleGrants DiscordRoleGrant[]

  @@unique([userId, badgeId])
  @@index([userId])
}

/// Learner-linked Discord identity (OAuth profile only; no token retention).
model DiscordAccount {
  id            String   @id @default(cuid())
  userId        String   @unique
  discordUserId String   @unique
  username      String
  globalName    String?
  avatar        String?
  linkedAt      DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user   User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  grants DiscordRoleGrant[]

  @@index([discordUserId])
}

/// Wallet-based project admin assignment (owner, manager, or analyst).
model ProjectAdmin {
  id              String           @id @default(cuid())
  productId       String
  userId          String
  role            ProjectAdminRole @default(manager)
  invitedByUserId String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User    @relation("ProjectAdminUser", fields: [userId], references: [id], onDelete: Cascade)
  invitedBy User?   @relation("ProjectAdminInviter", fields: [invitedByUserId], references: [id], onDelete: SetNull)

  @@unique([productId, userId])
  @@index([userId])
}

/// Per-product analytics configuration (terminology, KPIs, funnel, packs).
model AnalyticsProfile {
  id                    String   @id @default(cuid())
  productId             String   @unique
  schemaVersion         Int      @default(1)
  terminology           Json     @default("{}")
  kpiSet                String[] @default([])
  funnelStages          String[] @default([])
  sectionVisibility     String[] @default([])
  recommendationPolicy  Json     @default("{}")
  enabledProviderIds    String[] @default(["core"])
  featureFlags          Json     @default("{}")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

/// Installed Analytics Pack on a product.
model AnalyticsPackInstall {
  id          String   @id @default(cuid())
  productId   String
  packId      String
  packVersion String
  installedAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, packId])
  @@index([productId])
}

/// Skill / domain category for concept grouping.
model SkillCategory {
  id        String   @id @default(cuid())
  productId String
  slug      String
  name      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product  Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  concepts Concept[]

  @@unique([productId, slug])
  @@index([productId])
}

/// First-class learning concept for mastery analytics.
model Concept {
  id              String             @id @default(cuid())
  productId       String
  slug            String
  name            String
  description     String?
  category        String?
  skillCategoryId String?
  importance      ConceptImportance  @default(core)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  product           Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  skillCategory     SkillCategory?       @relation(fields: [skillCategoryId], references: [id], onDelete: SetNull)
  tags              ContentConceptTag[]
  relationsFrom     ConceptRelation[]    @relation("ConceptRelationFrom")
  relationsTo       ConceptRelation[]    @relation("ConceptRelationTo")
  objectiveLinks    LearningObjectiveConcept[]

  @@unique([productId, slug])
  @@index([productId])
  @@index([skillCategoryId])
}

model ConceptRelation {
  id           String              @id @default(cuid())
  fromConceptId String
  toConceptId   String
  type         ConceptRelationType @default(prerequisite)
  createdAt    DateTime            @default(now())

  fromConcept Concept @relation("ConceptRelationFrom", fields: [fromConceptId], references: [id], onDelete: Cascade)
  toConcept   Concept @relation("ConceptRelationTo", fields: [toConceptId], references: [id], onDelete: Cascade)

  @@unique([fromConceptId, toConceptId, type])
  @@index([toConceptId])
}

model LearningObjective {
  id          String   @id @default(cuid())
  productId   String
  slug        String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  product  Product                     @relation(fields: [productId], references: [id], onDelete: Cascade)
  concepts LearningObjectiveConcept[]

  @@unique([productId, slug])
  @@index([productId])
}

model LearningObjectiveConcept {
  id                  String @id @default(cuid())
  learningObjectiveId String
  conceptId           String
  weight              Float  @default(1)

  learningObjective LearningObjective @relation(fields: [learningObjectiveId], references: [id], onDelete: Cascade)
  concept           Concept           @relation(fields: [conceptId], references: [id], onDelete: Cascade)

  @@unique([learningObjectiveId, conceptId])
  @@index([conceptId])
}

/// Tags a lesson or question with a concept (exactly one of lessonId / questionId).
model ContentConceptTag {
  id         String             @id @default(cuid())
  conceptId  String
  lessonId   String?
  questionId String?
  weight     Float              @default(1)
  difficulty Int?
  importance ConceptImportance?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  concept  Concept   @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  lesson   Lesson?   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  question Question? @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([conceptId])
  @@index([lessonId])
  @@index([questionId])
  @@index([conceptId, questionId])
  @@index([conceptId, lessonId])
}

/// Partner conversion key definitions. Product UI / instrumentation deferred to Analytics V2.
model ConversionDefinition {
  id          String   @id @default(cuid())
  productId   String
  key         String
  label       String
  eventName   String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, key])
  @@index([productId])
}

/// Configurable readiness model (default: Learning Readiness).
model ReadinessModel {
  id             String   @id @default(cuid())
  productId      String
  name           String
  description    String?
  requirements   Json     @default("[]")
  levels         Json     @default("[]")
  readyThreshold Float    @default(70)
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

/// Project-scoped competency credential (distinct from Badge / BadgeAward).
model Certification {
  id             String               @id @default(cuid())
  productId      String
  slug           String
  name           String
  description    String?
  imageUrl       String?
  status         CertificationStatus  @default(draft)
  readyThreshold Float?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  product      Product                     @relation(fields: [productId], references: [id], onDelete: Cascade)
  requirements CertificationRequirement[]
  awards       CertificationAward[]

  @@unique([productId, slug])
  @@index([productId])
  @@index([status])
}

/// Requirement row for a certification (course, quiz, readiness, path, conversion, concept).
model CertificationRequirement {
  id              String                        @id @default(cuid())
  certificationId String
  type            CertificationRequirementType
  label           String?
  /// Type-specific config, e.g. { courseId }, { quizId, minScore }, { minReadinessScore }.
  config          Json                          @default("{}")
  weight          Float                         @default(1)
  sortOrder       Int                           @default(0)
  createdAt       DateTime                      @default(now())
  updatedAt       DateTime                      @updatedAt

  certification Certification @relation(fields: [certificationId], references: [id], onDelete: Cascade)

  @@index([certificationId])
}

/// Off-chain certification award (never auto-promoted from BadgeAward).
model CertificationAward {
  id                    String   @id @default(cuid())
  userId                String
  certificationId       String
  readinessScoreAtAward Float?
  verificationSlug      String?  @unique
  metadata              Json?
  awardedAt             DateTime @default(now())

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  certification Certification @relation(fields: [certificationId], references: [id], onDelete: Cascade)

  @@unique([userId, certificationId])
  @@index([userId])
  @@index([certificationId])
  @@index([awardedAt])
}

/// One Discord guild integration per ecosystem product.
model ProjectDiscordIntegration {
  id                        String                          @id @default(cuid())
  productId                 String                          @unique
  guildId                   String
  guildName                 String
  status                    ProjectDiscordIntegrationStatus @default(draft)
  botInstalled              Boolean                         @default(false)
  lastPermissionCheckStatus String?
  lastPermissionCheckAt     DateTime?
  createdByUserId           String?
  createdAt                 DateTime                        @default(now())
  updatedAt                 DateTime                        @updatedAt

  product   Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdBy User?             @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  roleRules DiscordRoleRule[]

  @@index([guildId])
}

/// Maps one published badge to one Discord role in a project server.
model DiscordRoleRule {
  id                          String                @id @default(cuid())
  productDiscordIntegrationId String
  badgeId                     String
  discordRoleId               String
  discordRoleName             String
  unlockLabel                 String?
  status                      DiscordRoleRuleStatus @default(draft)
  createdAt                   DateTime              @default(now())
  updatedAt                   DateTime              @updatedAt

  integration ProjectDiscordIntegration @relation(fields: [productDiscordIntegrationId], references: [id], onDelete: Cascade)
  badge       Badge                     @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  grants      DiscordRoleGrant[]

  @@unique([productDiscordIntegrationId, badgeId])
  @@unique([productDiscordIntegrationId, discordRoleId])
  @@index([badgeId])
}

/// Async job to grant a Discord role after a badge award.
model DiscordRoleGrant {
  id                String                 @id @default(cuid())
  userId            String
  discordAccountId  String?
  badgeAwardId      String
  discordRoleRuleId String
  guildId           String
  roleId            String
  status            DiscordRoleGrantStatus @default(pending)
  attemptCount      Int                    @default(0)
  lastAttemptAt     DateTime?
  grantedAt         DateTime?
  lastErrorCode     String?
  lastErrorMessage  String?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  discordAccount  DiscordAccount? @relation(fields: [discordAccountId], references: [id], onDelete: SetNull)
  badgeAward      BadgeAward      @relation(fields: [badgeAwardId], references: [id], onDelete: Cascade)
  discordRoleRule DiscordRoleRule @relation(fields: [discordRoleRuleId], references: [id], onDelete: Cascade)

  @@unique([badgeAwardId, discordRoleRuleId])
  @@index([status])
  @@index([userId])
}

/// Internal partner intake tracking and self-serve partner applications.
model PartnerIntake {
  id                      String                          @id @default(cuid())
  productId               String?
  applicantUserId         String?
  partnerName             String
  contactName             String?
  contactEmail            String?
  contactX                String?
  contactDiscord          String?
  contactTelegram         String?
  preferredContactMethod  PartnerPreferredContactMethod?
  projectName             String?
  projectDescription      String?
  officialWebsite         String?
  officialX               String?
  officialDiscord         String?
  officialTelegram        String?
  sourceMaterialUrl       String?
  requestedCourseTopic    String?
  reviewStatus            PartnerIntakeReviewStatus       @default(received)
  notes                   String?
  createdAt               DateTime                        @default(now())
  updatedAt               DateTime                        @updatedAt

  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  applicant User?    @relation("PartnerIntakeApplicant", fields: [applicantUserId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([reviewStatus])
  @@index([applicantUserId])
}

/// Append-only funnel and audit events (additive instrumentation).
model AnalyticsEvent {
  id                   String   @id @default(cuid())
  eventName            String
  occurredAt           DateTime @default(now())
  anonymousId          String?
  userId               String?
  walletAddress        String?
  sessionId            String?
  source               String
  path                 String?
  referrer             String?
  utmSource            String?
  utmMedium            String?
  utmCampaign          String?
  utmContent           String?
  ecosystemProjectId   String?
  ecosystemProjectSlug String?
  courseId             String?
  courseSlug           String?
  lessonId             String?
  quizId               String?
  badgeId              String?
  badgeAwardId         String?
  verificationSlug     String?
  metadata             Json?
  createdAt            DateTime @default(now())

  @@index([eventName])
  @@index([occurredAt])
  @@index([userId])
  @@index([courseId])
  @@index([ecosystemProjectId])
  @@index([ecosystemProjectId, eventName, occurredAt])
  @@index([ecosystemProjectId, userId, eventName])
}

/// Anonymous ecosystem benchmark rollups (Phase 5 prep — no partner UI until approved).
model EcosystemBenchmarkRollup {
  id         String   @id @default(cuid())
  metricId   String
  periodKey  String
  sampleSize Int
  p25        Float?
  p50        Float?
  p75        Float?
  computedAt DateTime @default(now())

  @@unique([metricId, periodKey])
  @@index([metricId, computedAt])
}

enum AnalyticsSnapshotStatus {
  fresh
  building
  queued
  stale
  error
}

enum AnalyticsSnapshotTrigger {
  hourly
  manual
}

/// Pre-aggregated analytics payload for partner dashboard reads.
model AnalyticsSnapshot {
  id            String                    @id @default(cuid())
  productId     String
  rangeKey      String
  periodStart   DateTime?
  periodEnd     DateTime
  compareKey    String                    @default("none")
  status        AnalyticsSnapshotStatus   @default(fresh)
  trigger       AnalyticsSnapshotTrigger  @default(hourly)
  schemaVersion Int                       @default(1)
  builtAt       DateTime                  @default(now())
  errorMessage  String?
  payload       Json                      @default("{}")
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, rangeKey, compareKey])
  @@index([productId, builtAt])
  @@index([status])
}
